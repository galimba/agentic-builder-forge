# agentic-builder-forge — target-repo branch namespace (Phase 3). Deployed enforce-protected file: agent
# edits are floor-denied; changes are authored as sandbox/ candidates and human-spliced under
# FORGE_ALLOW_HOOK_EDIT=1 (audit-logged).
#
# TARGET-repo builder branches are named "<FORGE_TARGET_BRANCH_NS>/builder/<id>-<slug>" (default
# "forge/agent/builder/<id>-<slug>"). SELF builds (the Forge control repo) keep "task/<id>-<slug>".
#
# TRUST (load-bearing): the reconcile close (harness/beads-lib.sh forge_reconcile_id_bound) reconstructs
# the EXPECTED head-ref prefix from THIS value to bind a close to the merged PR's id. It is therefore read
# ONLY from this enforce-protected file (agent env is stripped before the read) — an agent-writable prefix
# could route a forged head ref past the forgery-reject arm into the weaker record-match arm. Do not move
# this value out of an agent-immutable location.
FORGE_TARGET_BRANCH_NS="forge/agent"
