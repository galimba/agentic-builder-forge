# harness/targets.config — config-driven commands.
#
# Sourced by the hooks (.claude/hooks/*) and the loop runner. Hooks contain NO
# hardcoded test/lint/format commands; they read them from here. Pointing the
# skeleton at a different language is a config edit, NOT a code edit: change
# TARGET (or pass it inline, e.g. `TARGET=python ./harness/run-task.sh ...`).
#
# Shell-sourceable KEY=VALUE. Per-target stanzas are resolved by prefix:
#   eval "TEST_CMD=\$${TARGET}_TEST_CMD"   (and LINT_CMD / FORMAT_CMD / SANDBOX_GLOB)

TARGET="${TARGET:-typescript}"

# --- typescript (default) ---
typescript_TEST_CMD="pnpm test"
typescript_LINT_CMD="pnpm eslint . --no-error-on-unmatched-pattern"
typescript_FORMAT_CMD="pnpm prettier --write"
typescript_SANDBOX_GLOB="sandbox/**/*.ts"

# --- python (swap targets by setting TARGET=python) ---
python_TEST_CMD="pytest -q"
python_LINT_CMD="ruff check ."
python_FORMAT_CMD="ruff format"
python_SANDBOX_GLOB="sandbox/**/*.py"

# static website target — "green" = the product's own DoD shell tests pass
static_TEST_CMD="bash tests/dod/run.sh"
static_LINT_CMD="true"
static_FORMAT_CMD="true"
static_SANDBOX_GLOB="**"
