# harness/beads.config — config-driven Beads (bd) integration.
#
# Deployed enforcement-protected file: agent edits are floor-denied; changes are authored as sandbox/ candidates and human-spliced under FORGE_ALLOW_HOOK_EDIT=1 (audit-logged).
#
# Mirrors the targets.config idiom: the wrappers hardcode NO bd specifics — they read them here.
# Pointing at a different bd build/repo is a config edit, not a code edit. Every value below was
# VERIFIED against the live binary (bd v1.0.4).
#
# Sourced by harness/beads-lib.sh (which is sourced by run-task.sh + kill-switch.sh). KEY=VALUE.
#
# ONE-TIME HUMAN SETUP (sequencing matters — runtime depends on it; beads-lib preflight enforces both):
#   bd init --skip-agents --skip-hooks --non-interactive -p fx
#       # NEVER plain `bd init` — it writes AGENTS.md/CLAUDE.md/.claude/settings.json + git hooks and
#       # auto-commits. After init, review `git diff --cached` and STOP if anything enforcement-adjacent staged.
#   bd config set status.custom "in_review:wip"   # REQUIRED — else finish's `--status in_review` fails (unknown status)
#   git config beads.role maintainer              # silences the stderr role notice (keeps --json clean for jq)
#   bd version                                    # MUST equal BD_VERSION_PIN below (preflight fails on drift)

# --- binary + pinning -------------------------------------------------------
BD_BIN="${BD_BIN:-bd}"          # template default: resolved via PATH so a fresh clone works out
                                # of the box. init.sh replaces this with the DETECTED ABSOLUTE path:
                                # the deployed posture pins an absolute binary because the acceptance
                                # gate pins PATH and unsets BD_BIN (a bare `bd` would not resolve there).
BD_VERSION_PIN="1.0.4"          # checksum-verified gastownhall/beads release; bump deliberately

# --- repository identity ----------------------------------------------------
BD_PREFIX="fx"                  # ids look like fx-<hash>  (human runs: bd init -p fx ...)
# Claim/audit identity. One local identity by default; the per-user lever is BEADS_ACTOR/--actor.
BD_ACTOR="${BEADS_ACTOR:-$(git config user.name 2>/dev/null || echo forge-local)}"

# --- lifecycle --------------------------------------------------------------
BD_DEFAULT_PRIORITY="2"
# Awaiting-merge is a NATIVE custom status (verified: emitted in `list --json`, excluded from
# `bd ready`). Declared once at setup:  bd config set status.custom "$BD_REVIEW_STATUS_DECL"
BD_REVIEW_STATUS="in_review"
BD_REVIEW_STATUS_DECL="in_review:wip"
# Dependency edge type(s) shown in the DISPLAY-ONLY `blockers` contract field. Readiness itself is
# bd's authoritative `bd ready` (do NOT re-derive). 'blocks' verified; extend after a dep-type docs check.
BD_BLOCKING_TYPES="blocks"

# --- verified command surface (bd v1.0.4) -----------------------------------
# bd is ALWAYS run against the single DB in the MAIN checkout:  $BD_BIN -C "$ROOT" <args>
# Readers append 2>/dev/null (bd prints a beads.role notice to stderr; setup sets
# `git config beads.role maintainer`).  %s = issue id (or path / external-ref, per row).
BD_CLAIM_ARGS='update %s --claim --assignee %s'                 # atomic assignee + in_progress (idempotent)
BD_REVIEW_ARGS='update %s --status in_review --external-ref %s' # finish: hold-until-merge + PR ref
BD_CLOSE_ARGS='close %s --reason %s'                            # refuses if open blockers (we close our own)
BD_RELEASE_ARGS='update %s --status open --assignee ""'         # kill-switch: unclaim -> re-enters ready
BD_READY_JSON='ready --json'                                    # AUTHORITATIVE ready set
BD_LIST_JSON='list --json'                                      # open issues (add --all for closed)
# `board` Done lane: closed beads are excluded from `list`, so board adds a bounded recently-closed
# query. BD_CLOSED_WINDOW = days back; the cutoff is computed ABSOLUTE in run-task.sh (bd --closed-after
# accepts YYYY-MM-DD/RFC3339 only — verified v1.0.4). %s = that cutoff. LOCKED (probed against bd):
# --closed-after ALONE is open-scoped ([]); --status closed is REQUIRED to scope to closed beads.
BD_CLOSED_WINDOW="${BD_CLOSED_WINDOW:-30}"
BD_CLOSED_LIST_JSON='list --status closed --closed-after %s --json'
BD_SHOW_JSON='show %s --json'
BD_EXPORT_ARGS='export -o %s'                                   # force-flush tracked .beads/issues.jsonl
