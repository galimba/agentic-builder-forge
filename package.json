{
  "name": "agentic-builder-forge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Deterministic agentic build-harness template — enforcement-first, human-supervised. Clone, init, and run your own.",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "test": "bash tests/run-all.sh",
    "test:gate": "bash tests/gate/run.sh",
    "test:hooks": "bash tests/hooks/run.sh",
    "test:beads": "bash tests/beads/run.sh && bash tests/beads/integration.sh",
    "test:board": "bash tests/board/run.sh",
    "test:board-sync": "bash tests/board-sync/run.sh && bash tests/board-sync/readonly-gate.sh",
    "test:intake": "bash tests/intake/run.sh",
    "test:categories": "bash tests/categories/run.sh",
    "test:mechgate": "bash tests/mechgate/run.sh",
    "test:assembly": "bash tests/assembly/run.sh",
    "test:reviewer": "bash tests/reviewer/run.sh",
    "test:reviewer-record": "bash tests/reviewer-record/run.sh",
    "test:reviewer-disposition": "bash tests/reviewer-disposition/run.sh",
    "test:sandbox": "bash tests/sandbox/run.sh",
    "test:integration": "bash tests/integration/run.sh",
    "test:pristine": "bash tests/pristine/run.sh",
    "test:witness": "bash tests/witness/run.sh",
    "test:reaper": "bash tests/reaper/run.sh",
    "test:escape-classes": "bash tests/escape-classes/run.sh",
    "test:commitguard": "bash tests/commitguard/run.sh",
    "test:iso-guard": "bash tests/boundary/guard-selftest.sh",
    "test:boundary": "bash tests/boundary/run.sh",
    "test:bd-pin": "bash tests/boundary/bd-no-shelled-git.sh",
    "test:doc-hardening": "bash tests/boundary/doc-hardening.sh",
    "test:fold13-reconcile": "bash tests/boundary/fold13-reconcile-trustmodel.sh",
    "test:fold15-killswitch": "bash tests/boundary/fold15-killswitch-lifecycle.sh",
    "test:fold18-roundtrip": "bash tests/boundary/fold18-finish-record-roundtrip.sh",
    "test:fold17-integrity": "bash tests/boundary/fold17-integrity-toctou.sh",
    "test:fold12-bdbin": "bash tests/boundary/fold12-bdbin.sh",
    "test:fold14-target": "bash tests/boundary/fold14-target-selector.sh",
    "test:fold10-witness": "bash tests/boundary/fold10-witness-fsmonitor.sh",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test:fold21-path-pin": "bash tests/boundary/fold21-finish-path-pin.sh",
    "test:fold22-ld-strip": "bash tests/boundary/fold22-finish-ld-strip.sh",
    "test:fold23-envprefix": "bash tests/boundary/fold23-envprefix-classifier.sh",
    "test:fold24-reconcile-idbind": "bash tests/boundary/fold24-reconcile-idbind.sh",
    "test:fold25-bd-verb-deny": "bash tests/boundary/fold25-bd-verb-deny.sh",
    "test:reaper-trigger": "bash tests/reaper/trigger.sh",
    "test:reaper-concurrency": "bash tests/reaper/concurrency.sh",
    "test:fold26-redir-fd": "bash tests/boundary/fold26-redir-fd.sh",
    "test:fold27-interp-flags": "bash tests/boundary/fold27-interp-flags.sh",
    "test:fold28-vault-out-of-scope": "bash tests/boundary/fold28-vault-out-of-scope.sh",
    "test:fold29-hookspath-guard": "bash tests/boundary/fold29-hookspath-guard.sh",
    "test:fold30-multidigit-fd": "bash tests/boundary/fold30-multidigit-fd.sh",
    "test:fold19-gh": "bash tests/boundary/fold19-gh-convergence.sh",
    "test:fold20-coldstart": "bash tests/boundary/fold20-bd-coldstart.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^26.1.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
