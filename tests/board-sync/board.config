BOARD_FIELD_BLOCKED_BY="fld:Blocked-by"
BOARD_FIELD_PRIORITY="fld:Priority"
BOARD_OPT_STATUS_BACKLOG="opt:Status:Backlog"
BOARD_OPT_STATUS_READY="opt:Status:Ready"
BOARD_OPT_STATUS_IN_PROGRESS="opt:Status:In progress"
BOARD_OPT_STATUS_IN_REVIEW="opt:Status:In review"
BOARD_OPT_STATUS_BLOCKED="opt:Status:Blocked"
BOARD_OPT_STATUS_DONE="opt:Status:Done"
BOARD_OPT_PRIORITY_P0="opt:Priority:P0"
BOARD_OPT_PRIORITY_P1="opt:Priority:P1"
BOARD_OPT_PRIORITY_P2="opt:Priority:P2"
